{
  "manifest_version": 3,
  "name": "Cookidoo Rezept-Finder",
  "version": "2.0.0",
  "description": "Findet Cookidoo-Rezepte (≤45 Min, ≥4 Sterne, Fleisch/Fisch/Veggie) und überträgt Zutaten an Bring! Einkaufsliste.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://cookidoo.de/*",
    "https://cookidoo.vorwerk.de/*",
    "https://web.getbring.com/*",
    "https://api.getbring.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "dashboard.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
